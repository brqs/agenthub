# ============================================================
# AgentHub 环境变量模板
# 用法：cp .env.example .env 并填入真实值
# ============================================================

# ─── Database (PostgreSQL) ───
POSTGRES_USER=agenthub
POSTGRES_PASSWORD=agenthub_dev_pw
POSTGRES_DB=agenthub
DATABASE_URL=postgresql+asyncpg://agenthub:agenthub_dev_pw@postgres:5432/agenthub

# ─── Cache (Redis) ───
REDIS_URL=redis://redis:6379/0

# ─── Authentication ───
# 生产环境必须用强随机串：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-please-use-a-strong-random-string-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ─── AI Providers ───
# 至少配置一个，没配的 Provider 对应 Agent 会不可用
ANTHROPIC_API_KEY=sk-ant-your-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
OPENAI_API_KEY=sk-your-key-here

# 可选：自定义 Provider Base URL（如代理）
ANTHROPIC_BASE_URL=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_BASE_URL=

# ─── Context Compression ───
# hybrid 会优先使用 DeepSeek 生成高质量摘要；失败时自动回退到 rules-v2
CONTEXT_COMPRESSION_MODE=hybrid
CONTEXT_COMPRESSION_PROVIDER=deepseek
CONTEXT_COMPRESSION_MODEL=deepseek-v4-flash
CONTEXT_COMPRESSION_API_KEY=sk-your-compression-key-here
CONTEXT_COMPRESSION_BASE_URL=https://api.deepseek.com
CONTEXT_SUMMARY_MAX_TOKENS=1200
CONTEXT_RECENT_RAW_KEEP=12

# Workspaces
WORKSPACE_BASE_DIR=/workspaces
WORKSPACE_MAX_READ_BYTES=1048576

# ─── CORS ───
# 多个 origin 用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ─── Server ───
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
ENVIRONMENT=development

# ─── Workspace Preview ───
PREVIEW_ENABLED=true
PREVIEW_PORT_START=8082
PREVIEW_PORT_END=8182
PREVIEW_PUBLIC_BASE_URL=http://111.229.151.159
PREVIEW_START_TIMEOUT_SECONDS=15
PREVIEW_IDLE_TTL_SECONDS=1800

# ─── Orchestrator Defaults ───
# Defaults for the built-in orchestrator when DB config does not explicitly override them.
ORCHESTRATOR_LLM_PLANNING_DEFAULT=true
ORCHESTRATOR_PARALLEL_ENABLED_DEFAULT=true
ORCHESTRATOR_PARALLEL_MAX_CONCURRENCY_DEFAULT=3

# ─── Frontend (Vite) ───
# 这些变量供前端使用，必须以 VITE_ 开头
VITE_API_BASE_URL=http://localhost:8000
