# ============================================================
# AgentHub 环境变量模板
# 用法：cp .env.example .env 并填入真实值
# ============================================================

# ─── Database (PostgreSQL) ───
POSTGRES_USER=agenthub
POSTGRES_PASSWORD=agenthub_dev_pw
POSTGRES_DB=agenthub
DATABASE_URL=postgresql+asyncpg://agenthub:agenthub_dev_pw@postgres:5432/agenthub

# ─── Cache (Redis) ───
REDIS_URL=redis://redis:6379/0

# ─── Authentication ───
# 生产环境必须用强随机串：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-please-use-a-strong-random-string-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ─── AI Providers ───
# 至少配置一个，没配的 Provider 对应 Agent 会不可用
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# 可选：自定义 Provider Base URL（如代理）
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=

# ─── CORS ───
# 多个 origin 用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ─── Server ───
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ─── Frontend (Vite) ───
# 这些变量供前端使用，必须以 VITE_ 开头
VITE_API_BASE_URL=http://localhost:8000
