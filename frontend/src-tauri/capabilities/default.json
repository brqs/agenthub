{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AgentHub P3 desktop capability set. Only validated stack and user-selected file operations are exposed.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "desktop-management",
    "deep-link:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-stat",
    "fs:allow-write-file",
    "updater:default"
  ]
}
