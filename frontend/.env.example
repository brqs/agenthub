# Backend base URL.
# 留空表示走 Vite dev proxy（推荐，自动转发 /api → VITE_DEV_PROXY_TARGET）。
# 若设置，axios 会直连后端，需要后端开启 CORS。
VITE_API_BASE_URL=

# 开发代理目标。默认指向远端 demo 后端，可改成 http://localhost:8000 接本地后端。
VITE_DEV_PROXY_TARGET=http://111.229.151.159:8000

# Mock 开关：
#   true  → hooks/adapters 返回本地 Mock 数据，不调后端（默认，比赛 Demo 用）
#   false → 走真实后端 REST
VITE_USE_MOCK_API=true

# SSE Mock 开关：不设置时跟随 VITE_USE_MOCK_API。
# 可以单独把 REST 切真后端、SSE 仍走 Mock。
VITE_USE_MOCK_SSE=
